# =============================================================================
# 这是「可提交到 GitHub」的密钥配置副本模板
# 真实密钥请复制本文件后填写，文件名建议改为 .env（不要提交）
# =============================================================================
#
# 【操作步骤】
# 1. 复制：
#      Copy-Item .env-副本 .env          # PowerShell
#      copy .env-副本 .env               # CMD
#      cp .env-副本 .env                 # bash
# 2. 编辑 .env，替换 YOUR_xxx 为真实值
# 3. 确认 git status 里没有 .env
#
# 【传递方式】
# - 同事之间：用密码管理器共享，或当面/加密通道传 .env 内容
# - 不要：提交 Git、发公开聊天、把密钥写进 README / Issue / PR
# - 部署：GitHub Actions Secrets / 服务器 EnvironmentFile / K8s Secret
# - Docker：根目录放置 .env 后执行 docker compose，会自动注入变量
#
# 说明：本文件与 .env.example 内容等价，任选其一作为模板即可。
# =============================================================================

DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY

TENCENTCLOUD_SECRET_ID=YOUR_TENCENTCLOUD_SECRET_ID
TENCENTCLOUD_SECRET_KEY=YOUR_TENCENTCLOUD_SECRET_KEY
TENCENTCLOUD_API_BASE_HOST=tencentcloudapi.com

MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
